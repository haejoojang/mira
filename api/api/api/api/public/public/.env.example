# Copy this file's contents into Vercel's Environment Variables settings.
# Never commit an actual .env file with real values to GitHub.

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

RESEND_API_KEY=

ANTHROPIC_API_KEY=

# Any random long string — protects /api/reminders from being called by anyone
# but Vercel's own cron scheduler.
CRON_SECRET=
